# Production env for the Hetzner host. Copy to .env and fill in real values.
# NEVER commit the real .env. The real TARGET_DATE is a secret too — it's
# part of the piece. Treat it the same as SECRET_KEY.

# When the count started (YYYY-MM-DD or RFC3339).
START_DATE=YYYY-MM-DD

# The unlock moment (YYYY-MM-DD or RFC3339). Can include a time of day.
TARGET_DATE=YYYY-MM-DDTHH:MM:SSZ

# Only needed if TARGET_DATE has a time component. Must match the date string
# that was passed to scripts/encrypt.mjs when the ciphertext was produced.
ENCRYPT_DATE=YYYY-MM-DD

# The real secret. Never commit. Rotating this invalidates the ciphertext.
SECRET_KEY=replace-me-with-the-real-key
