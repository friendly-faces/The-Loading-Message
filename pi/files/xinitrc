#!/bin/sh
# X session for the kiosk. No window manager — chromium owns the screen.

xset s off
xset -dpms
xset s noblank

unclutter -idle 0 -root &

exec chromium-browser \
  --kiosk \
  --noerrdialogs \
  --disable-infobars \
  --no-first-run \
  --disable-translate \
  --disable-pinch \
  --overscroll-history-navigation=0 \
  --check-for-update-interval=31536000 \
  --allow-file-access-from-files \
  --disable-features=Translate,TranslateUI \
  "file:///opt/loading-message/web/index.html"
