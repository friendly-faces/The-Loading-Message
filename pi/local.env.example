# Copy this to local.env (gitignored) and fill in real values before
# running ./setup.sh on the Pi.
#
# local.env is installed to /etc/loading-message/env (root:root, 0600) and
# loaded by the systemd unit.

LOADING_MESSAGE_MODE=standalone
MESSAGE_PATH=/opt/loading-message/message.json

# When the percentage starts climbing.
START_DATE=2026-01-01T00:00:00Z

# When the percentage hits 100% and the message reveals.
TARGET_DATE=2226-01-01T00:00:00Z

# Optional. Defaults to TARGET_DATE formatted as YYYY-MM-DD.
# Only set this if api/message.json was encrypted with a different date than
# the target date itself.
# ENCRYPT_DATE=2226-01-01

# The real key the message was encrypted with. Without this, decryption fails.
SECRET_KEY=replace-me-with-the-real-key
